# Copy this file to .env and fill in real values. Never commit .env itself.

# Postgres in production, sqlite is fine for local dev (leave default to use sqlite)
DATABASE_URL=postgresql://user:password@localhost:5432/pulse

# Reddit — create a "script" app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=pulse-app/0.1 by yourusername

# NewsAPI — free dev key at https://newsapi.org
NEWSAPI_KEY=

# How often to re-run ingestion, in minutes (15 is the shortest safe
# interval on NewsAPI's free 100/day quota — see README for the math)
INGEST_INTERVAL_MINUTES=15

# Sign in with Apple / session tokens — generate with `openssl rand -hex 32`
SESSION_SECRET=

# Demo/testing only — leave both blank/false for any deployment a real
# device might connect to. Enabling this exposes an endpoint that grants
# free "Premium" access with no real payment verification.
DEMO_MODE=false
DEMO_MODE_SECRET=
